<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           styleClass="ui-root"
           maxWidth="Infinity"
           maxHeight="Infinity"
           minWidth="0"
           minHeight="0">

    <VBox alignment="CENTER"
          spacing="20"
          maxWidth="Infinity"
          maxHeight="Infinity">

        <Label text="Select Level" styleClass="title-label" />

        <Button text="Level 1"
                onAction="#startLevel1"
                styleClass="level-button" />

        <Button text="Level 2"
                disable="true"
                styleClass="level-button locked-level-button" />

        <Button text="Level 3"
                disable="true"
                styleClass="level-button locked-level-button" />

        <Button text="Back"
                onAction="#backToMainMenu"
                styleClass="secondary-button" />

    </VBox>
</StackPane>


