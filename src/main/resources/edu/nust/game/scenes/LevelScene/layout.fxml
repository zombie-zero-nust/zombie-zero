<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<StackPane styleClass="ui-root" style="-fx-padding: 0;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12">

    <HBox StackPane.alignment="TOP_LEFT" alignment="TOP_LEFT" fillHeight="false" style="-fx-padding: 20;">
        <VBox fx:id="healthBarContainer" />
        <Label fx:id="healthLabel" visible="false" managed="false" />
    </HBox>

    <HBox StackPane.alignment="TOP_RIGHT" alignment="TOP_RIGHT" fillHeight="false" style="-fx-padding: 20;">
        <VBox prefWidth="280"
              maxHeight="-1.0"
              style="-fx-background-color: rgba(0, 0, 0, 0.7);
                     -fx-border-color: #00FF00;
                     -fx-border-width: 2;
                     -fx-padding: 12;
                     -fx-spacing: 10;
                     -fx-background-radius: 5;
                     -fx-border-radius: 5;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="SCORE" style="-fx-text-fill: #00FF00; -fx-font-size: 11; -fx-font-weight: bold; -fx-font-family: 'Courier New';" />
                <Label fx:id="scoreLabel" text="0" style="-fx-text-fill: #FFFF00; -fx-font-size: 12; -fx-font-weight: bold; -fx-font-family: 'Courier New';" />
            </HBox>
            <Separator />
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="BULLETS" style="-fx-text-fill: #00FF00; -fx-font-size: 11; -fx-font-weight: bold; -fx-font-family: 'Courier New';" />
                <Label fx:id="ammoLabel" text="20 / 20" style="-fx-text-fill: #FFFF00; -fx-font-size: 12; -fx-font-weight: bold; -fx-font-family: 'Courier New';" />
            </HBox>
            <VBox fx:id="ammoBarContainer" />
            <Label fx:id="reloadLabel" visible="false" managed="false" />
        </VBox>

    </HBox>

    <!-- Pause Overlay - Full Screen with Centered Content -->
    <StackPane fx:id="pauseOverlay" managed="false" styleClass="pauseOverlay" visible="false"
               StackPane.alignment="CENTER" maxWidth="Infinity" maxHeight="Infinity" minWidth="0" minHeight="0">

        <VBox alignment="CENTER" spacing="20" styleClass="overlay-content-box">
            <Label fx:id="overlayTitleLabel" styleClass="overlay-title" text="Paused" />
            <Button fx:id="resumeButton" onAction="#resumeGame" styleClass="primary-button" text="Resume" />
            <Button onAction="#retryLevel" styleClass="primary-button" text="Retry" />
            <Button onAction="#exitToMainMenu" styleClass="primary-button" text="Exit to Main Menu" />
        </VBox>

    </StackPane>

</StackPane>

