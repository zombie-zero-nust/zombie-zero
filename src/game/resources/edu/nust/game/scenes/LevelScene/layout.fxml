<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<StackPane style="-fx-padding: 0;" styleClass="ui-root" xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1">
    <HBox alignment="TOP_LEFT" fillHeight="false" style="-fx-padding: 16;" StackPane.alignment="TOP_LEFT">
        <VBox alignment="TOP_LEFT" spacing="10">
            <VBox fx:id="healthBarContainer"/>
            <Label fx:id="healthLabel" managed="false" visible="false"/>
        </VBox>
    </HBox>
    <HBox alignment="TOP_RIGHT" fillHeight="false" prefWidth="200" style="-fx-padding: 16;"
          StackPane.alignment="TOP_RIGHT">
        <VBox alignment="TOP_RIGHT" spacing="10"
              style="-fx-background-color: #7a7a8a; -fx-border-color: #3a3a3a; -fx-border-width: 2; -fx-border-radius: 5; -fx-background-radius: 5; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.45), 6, 0, 2, 2);">
            <VBox>
                <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 8;" prefWidth="365">
                    <ImageView fx:id="gunIconView" fitHeight="68" fitWidth="120" preserveRatio="true" smooth="false"
                               StackPane.alignment="CENTER"/>
                    <VBox fx:id="ammoBarContainer" alignment="CENTER_LEFT"
                          HBox.hgrow="ALWAYS"/>
                    <Label fx:id="ammoLabel"
                           style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold; -fx-font-family: 'Courier New'; -fx-padding: 0 0 0 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.85), 3, 0.6, 1, 1);"
                           text="6 / 6"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
    <StackPane fx:id="pauseOverlay" managed="false" maxHeight="Infinity" maxWidth="Infinity" minHeight="0" minWidth="0"
               styleClass="pauseOverlay" visible="false" StackPane.alignment="CENTER">
        <VBox alignment="CENTER" spacing="20" styleClass="overlay-content-box">
            <Region fx:id="pauseHeadingTile" styleClass="pause-heading-tile"/>
            <Region fx:id="gameOverHeadingTile" managed="false" styleClass="gameover-heading-tile" visible="false"/>
            <Label fx:id="overlayTitleLabel" managed="false" styleClass="overlay-title" text="Game Over"
                   visible="false"/>
            <StackPane fx:id="scoreDisplayControllerContainer" alignment="CENTER" managed="false" maxWidth="400"
                       prefWidth="350" visible="false"/> <!-- Pause buttons -->
            <Button fx:id="resumeButton" onAction="#resumeGame" styleClass="pause-button-tile, resume-button-tile"
                    text=""/>
            <Button fx:id="pauseRetryButton" onAction="#retryLevel" styleClass="pause-button-tile, retry-button-tile"
                    text=""/>
            <Button fx:id="pauseExitButton" onAction="#exitToMainMenu"
                    styleClass="pause-button-tile, overlay-exit-button-tile" text=""/> <!-- Game-over buttons -->
            <Button fx:id="gameOverNewGameButton" managed="false" onAction="#startNewGame"
                    styleClass="gameover-button-tile, gameover-newgame-button-tile" text="" visible="false"/>
            <Button fx:id="gameOverMainMenuButton" managed="false" onAction="#exitToMainMenu"
                    styleClass="gameover-button-tile, gameover-mainmenu-button-tile" text="" visible="false"/>
            <Button fx:id="gameOverHighScoresButton" managed="false" onAction="#viewHighScores"
                    styleClass="gameover-button-tile, gameover-highscores-button-tile" text="" visible="false"/>
        </VBox>
    </StackPane>
</StackPane>
