<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml"
            styleClass="root"
            maxWidth="Infinity"
            maxHeight="Infinity"
            minWidth="0"
            minHeight="0">

    <StackPane styleClass="ui-root"
               AnchorPane.topAnchor="0"
               AnchorPane.leftAnchor="0"
               AnchorPane.rightAnchor="0"
               AnchorPane.bottomAnchor="0"
               maxWidth="Infinity"
               maxHeight="Infinity"
               minWidth="0"
               minHeight="0">

        <VBox alignment="CENTER"
              spacing="18"
              maxWidth="Infinity"
              maxHeight="Infinity">

            <Label fx:id="nameErrorLabel"
                   styleClass="name-error-label"/>

            <TextField fx:id="playerNameField"
                       promptText="Enter player name"
                       styleClass="name-input"/>

            <HBox alignment="CENTER" spacing="40" styleClass="level-row, level-row-top">
                <StackPane styleClass="level-tile, level1-tile"
                           onMouseClicked="#startLevel1TileClicked"/>

                <StackPane styleClass="level-tile, level2-tile, locked-level-tile"
                           disable="true"/>
            </HBox>

            <HBox alignment="CENTER" spacing="40" styleClass="level-row, level-row-bottom">
                <StackPane styleClass="level-tile, level3-tile, locked-level-tile"
                           disable="true"/>

                <StackPane styleClass="level-tile, level4-tile, locked-level-tile"
                           disable="true"/>
            </HBox>

        </VBox>
    </StackPane>

    <Button styleClass="back-image-button"
            onAction="#goBack"
            AnchorPane.topAnchor="10"
            AnchorPane.rightAnchor="10"/>
</AnchorPane>
